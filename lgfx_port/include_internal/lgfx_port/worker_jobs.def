// include/lgfx_port/worker_jobs.def
//
// Canonical worker job list.
// X(KIND, union_member, union_fields, exec_body)
// exec_body must set job->err.

X(INIT, init, const void *owner_token; lgfx_open_config_overrides_t open_config_overrides;, job->err = lgfx_device_init_with_open_config(&job->a.init.open_config_overrides, job->a.init.owner_token);)
